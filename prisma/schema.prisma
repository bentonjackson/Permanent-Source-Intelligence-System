generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RoleKey {
  admin
  rep
}

enum PipelineStage {
  NEW
  RESEARCH_BUILDER
  READY_TO_BID
  CONTACTED
  QUOTED
  WON
  LOST
  NOT_A_FIT
}

enum OpportunityType {
  VACANT_LOT_NEW_BUILD
  SUBDIVISION_LOT
  PRE_ISSUANCE_HOME
  ISSUED_NEW_HOME
  OTHER_NON_PRIORITY
}

enum BuildReadiness {
  EARLY_SIGNAL
  PLAN_SUBMITTED
  PERMIT_REVIEW
  PERMIT_ISSUED
}

enum BidStatus {
  NOT_REVIEWED
  RESEARCHING_BUILDER
  READY_TO_CONTACT
  CONTACTED
  BID_REQUESTED
  QUOTED
  WON
  LOST
  NOT_A_FIT
}

enum ProjectSegment {
  SINGLE_FAMILY
  MULTIFAMILY
  COMMERCIAL
}

enum PermitClassification {
  NEW_RESIDENTIAL_CONSTRUCTION
  SINGLE_FAMILY_HOME
  MULTI_FAMILY
  ACCESSORY_BUILDING
  REMODEL_REPAIR
  COMMERCIAL
  UNKNOWN_NEEDS_REVIEW
}

enum SourceSyncStatus {
  idle
  running
  success
  warning
  failed
}

enum ConnectorType {
  DOCUMENT
  SEARCH
  PORTAL
  GIS_PLANNING
}

enum SourceRecordChangeStatus {
  NEW
  UPDATED
  UNCHANGED
  ERROR
}

enum SourceRecordParseStatus {
  PENDING
  PARSED
  SKIPPED
  FAILED
}

enum EntityRoleType {
  BUILDER
  GENERAL_CONTRACTOR
  DEVELOPER
  OWNER
  HOLDING_COMPANY
  PERSON
  UNKNOWN
}

enum ContactQualityTier {
  HIGH
  MEDIUM
  LOW
  RESEARCH_REQUIRED
}

enum ContactQualityBand {
  TIER_1
  TIER_2
  TIER_3
  TIER_4
  TIER_5
}

enum RegistrationStatus {
  ACTIVE
  INACTIVE
  UNKNOWN
  PENDING
  NOT_FOUND
}

enum SignalType {
  NEW_RESIDENTIAL_PERMIT
  NEW_MULTIFAMILY_PERMIT
  PARCEL_DEVELOPMENT
  SUBDIVISION_PLAT
  REZONING_LAND_USE
  PLANNING_AGENDA
  SITE_PREP
  UTILITY_OR_GRADING
  CLUSTER_ACTIVITY
  ASSESSOR_VALUE_MOVEMENT
  OTHER
}

enum DevelopmentStage {
  EARLY_LAND_SIGNAL
  PLANNING_REVIEW
  PLAT_REVIEW
  SITE_PREP
  PERMIT_INTAKE
  PERMIT_REVIEW
  PERMIT_ISSUED
}

enum SourceStrength {
  HIGH
  MEDIUM
  LOW
}

enum ReadinessToContact {
  NOW
  SOON
  RESEARCH
  WATCH
}

enum ContactResolutionStatus {
  RESOLVED
  BUILDER_ONLY
  WEAK_ENTITY
  UNKNOWN
}

enum ReviewQueueType {
  PARSE_FAILURE
  WEAK_IDENTITY
  AMBIGUOUS_MATCH
  MISSING_CONTACT
  MISSING_FIELD
  STALE_SOURCE
  DUPLICATE_RECORD
  SOURCE_FAILURE
}

enum ReviewQueueStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  DISMISSED
}

model Organization {
  id          String       @id @default(cuid())
  name        String
  slug        String       @unique
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  memberships Membership[]
  sources     Source[]
  builders    Builder[]
  companies   Company[]
  leads       Lead[]
  contacts    Contact[]
  activities  Activity[]
  notes       Note[]
  territories Territory[]
  watchlists  Watchlist[]
  plotOpportunities PlotOpportunity[]
  entityMatches EntityMatch[]
  enrichmentResults EnrichmentResult[]
  sourceHealthChecks SourceHealthCheck[]
  reviewQueueItems ReviewQueueItem[]
  opportunityStageHistory OpportunityStageHistory[]
  opportunityContactSnapshots OpportunityContactSnapshot[]
}

model Membership {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  clerkUserId    String
  email          String
  displayName    String
  role           RoleKey
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  assignedLeads  Lead[]
  plotOpportunities PlotOpportunity[]
  createdActivities Activity[] @relation("ActivityCreatedByMembership")
  opportunityStageChanges OpportunityStageHistory[] @relation("OpportunityStageChangedByMembership")
}

model County {
  id            String         @id @default(cuid())
  name          String         @unique
  state         String         @default("IA")
  cities        City[]
  jurisdictions Jurisdiction[]
  properties    Property[]
}

model City {
  id            String         @id @default(cuid())
  name          String
  countyId      String
  county        County         @relation(fields: [countyId], references: [id], onDelete: Restrict)
  jurisdictions Jurisdiction[]
  properties    Property[]

  @@unique([name, countyId])
}

model Jurisdiction {
  id            String    @id @default(cuid())
  name          String
  countyId      String
  county        County    @relation(fields: [countyId], references: [id], onDelete: Restrict)
  cityId        String?
  city          City?     @relation(fields: [cityId], references: [id], onDelete: SetNull)
  sources       Source[]
  permits       Permit[]

  @@unique([name, countyId])
}

model Territory {
  id             String         @id @default(cuid())
  organizationId String
  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  slug           String
  type           String
  radiusMiles    Float?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  rules          TerritoryRule[]

  @@unique([organizationId, slug])
}

model TerritoryRule {
  id          String    @id @default(cuid())
  territoryId String
  territory   Territory @relation(fields: [territoryId], references: [id], onDelete: Cascade)
  ruleType    String
  ruleValue   String
}

model Source {
  id                    String           @id @default(cuid())
  organizationId        String
  organization          Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  jurisdictionId        String?
  jurisdiction          Jurisdiction?    @relation(fields: [jurisdictionId], references: [id], onDelete: SetNull)
  name                  String
  slug                  String
  county                String?
  city                  String?
  sourceScope           String?
  countyRadiusEligible  Boolean          @default(false)
  countySelectorVisible Boolean          @default(false)
  officialSourceType    String?
  connectorType         ConnectorType    @default(DOCUMENT)
  priorityRank          Int              @default(100)
  sourceType            String
  parserType            String
  sourceUrl             String
  active                Boolean          @default(true)
  authRequired          Boolean          @default(false)
  syncFrequency         String
  sourceConfidenceScore Int              @default(0)
  sourceFreshnessScore  Int              @default(0)
  syncStatus            SourceSyncStatus @default(idle)
  lastSuccessfulSync    DateTime?
  rawRecords            RawRecord[]
  syncRuns              SourceSyncRun[]
  plotOpportunities     PlotOpportunity[]
  permits               Permit[]
  healthChecks          SourceHealthCheck[]
  reviewQueueItems      ReviewQueueItem[]

  @@unique([organizationId, slug])
}

model SourceSyncRun {
  id             String           @id @default(cuid())
  sourceId       String
  source         Source           @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  startedAt      DateTime         @default(now())
  finishedAt     DateTime?
  status         SourceSyncStatus @default(running)
  fetchedCount   Int              @default(0)
  normalizedCount Int             @default(0)
  dedupedCount   Int              @default(0)
  newRecordCount Int              @default(0)
  updatedRecordCount Int          @default(0)
  unchangedRecordCount Int        @default(0)
  errorRecordCount Int            @default(0)
  blockedCount   Int              @default(0)
  completenessScore Int           @default(0)
  driftScore     Int              @default(0)
  message        String?
  logs           SourceSyncLog[]
  rawRecords     RawRecord[]
  healthChecks   SourceHealthCheck[]
}

model SourceSyncLog {
  id        String        @id @default(cuid())
  runId     String
  run       SourceSyncRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  level     String
  message   String
  createdAt DateTime      @default(now())
}

model RawRecord {
  id          String   @id @default(cuid())
  sourceId    String
  source      Source   @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  runId       String?
  run         SourceSyncRun? @relation(fields: [runId], references: [id], onDelete: SetNull)
  externalId  String
  sourceUrl   String?
  recordKey   String   @default("")
  contentHash String   @default("")
  firstSeenAt DateTime @default(now())
  lastSeenAt  DateTime @default(now())
  changeStatus SourceRecordChangeStatus @default(NEW)
  parseStatus SourceRecordParseStatus   @default(PENDING)
  recordVersion Int   @default(1)
  errorMessage String?
  blockedReason String?
  payload     Json
  dedupeHash  String
  fetchedAt   DateTime
  createdAt   DateTime @default(now())
  permitId    String?
  permit      Permit?  @relation(fields: [permitId], references: [id], onDelete: SetNull)
  reviewQueueItems ReviewQueueItem[]

  @@unique([sourceId, dedupeHash])
}

model Builder {
  id                  String         @id @default(cuid())
  organizationId      String
  organization        Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  companyId           String?
  company             Company?       @relation(fields: [companyId], references: [id], onDelete: SetNull)
  name                String
  normalizedName      String
  builderIdentityKey  String?
  rawSourceName       String?
  rawSourceNames      String[]        @default([])
  preferredSalesName  String?
  roleType            EntityRoleType @default(UNKNOWN)
  contactQualityTier  ContactQualityTier @default(RESEARCH_REQUIRED)
  preferredContactTarget String?
  phone               String?
  email               String?
  website             String?
  mailingAddress      String?
  cityState           String?
  contractorRegistrationNumber String?
  contractorRegistrationStatus RegistrationStatus @default(UNKNOWN)
  businessEntityNumber String?
  businessEntityStatus RegistrationStatus @default(UNKNOWN)
  notes               String?
  confidenceScore     Int            @default(0)
  roleConfidenceScore Int            @default(0)
  contactQualityScore Int            @default(0)
  contactQualityBand  ContactQualityBand @default(TIER_5)
  builderHeatScore    Int            @default(0)
  activeProperties    Int            @default(0)
  totalLandValue      Decimal?       @db.Decimal(12, 2)
  totalImprovementValue Decimal?     @db.Decimal(12, 2)
  nextBestAction      String?
  lastEnrichedAt      DateTime?
  lastVerifiedAt      DateTime?
  matchProvenance     Json?
  aliases             BuilderAlias[]
  permits             Permit[]
  leads               Lead[]
  contacts            Contact[]
  plotOpportunities   PlotOpportunity[]
  entityMatches       EntityMatch[]
  enrichmentResults   EnrichmentResult[]
  contactSnapshots    OpportunityContactSnapshot[] @relation("SnapshotPrimaryEntity")
  reviewQueueItems    ReviewQueueItem[]

  @@unique([organizationId, normalizedName])
  @@index([builderIdentityKey])
}

model BuilderAlias {
  id             String   @id @default(cuid())
  builderId      String
  builder        Builder  @relation(fields: [builderId], references: [id], onDelete: Cascade)
  rawName        String
  normalizedName String?
  fingerprint    String?
  sourceLabel    String?
  sourceUrl      String?
  firstSeenAt    DateTime @default(now())
  lastSeenAt     DateTime @default(now())
}

model Company {
  id                String           @id @default(cuid())
  organizationId    String
  organization      Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  legalName         String
  normalizedName    String
  rawSourceName     String?
  rawSourceNames    String[]         @default([])
  preferredSalesName String?
  roleType          EntityRoleType   @default(UNKNOWN)
  contactQualityTier ContactQualityTier @default(RESEARCH_REQUIRED)
  preferredContactTarget String?
  entityConfidenceScore Int          @default(0)
  phone             String?
  email             String?
  website           String?
  mailingAddress    String?
  cityState         String?
  contractorRegistrationNumber String?
  contractorRegistrationStatus RegistrationStatus @default(UNKNOWN)
  businessEntityNumber String?
  businessEntityStatus RegistrationStatus @default(UNKNOWN)
  roleConfidenceScore Int           @default(0)
  contactQualityScore Int           @default(0)
  contactQualityBand ContactQualityBand @default(TIER_5)
  contactSource     String?
  contactUrl        String?
  lastEnrichedAt    DateTime?
  lastVerifiedAt    DateTime?
  matchProvenance   Json?
  builders          Builder[]
  contacts          Contact[]
  entityMatches     EntityMatch[]
  enrichmentResults EnrichmentResult[]
  leads             Lead[]

  @@unique([organizationId, normalizedName])
}

model Contact {
  id                String         @id @default(cuid())
  organizationId    String
  organization      Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  builderId         String?
  builder           Builder?       @relation(fields: [builderId], references: [id], onDelete: SetNull)
  companyId         String?
  company           Company?       @relation(fields: [companyId], references: [id], onDelete: SetNull)
  opportunityId     String?
  opportunity       PlotOpportunity? @relation(fields: [opportunityId], references: [id], onDelete: SetNull)
  fullName          String?
  firstName         String?
  lastName          String?
  companyName       String?
  email             String?
  normalizedEmail   String?
  phone             String?
  normalizedPhone   String?
  mobilePhone       String?
  officePhone       String?
  roleTitle         String?
  publicProfileUrl  String?
  website           String?
  linkedinUrl       String?
  preferredContactMethod String?
  bestTimeToContact String?
  notes             String?
  mailingAddress    String?
  cityState         String?
  sourceLabel       String?
  sourceUrl         String?
  confidenceScore   Int            @default(0)
  qualityScore      Int            @default(0)
  qualityBand       ContactQualityBand @default(TIER_5)
  contactSourceRank Int            @default(0)
  isPrimary         Boolean        @default(false)
  lastVerifiedAt    DateTime?
  lastEnrichedAt    DateTime?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @default(now()) @updatedAt
  activities        Activity[]
  contactSnapshots  OpportunityContactSnapshot[] @relation("SnapshotPrimaryContact")

  @@index([opportunityId, isPrimary])
  @@index([builderId, normalizedEmail])
  @@index([companyId, normalizedEmail])
}

model Property {
  id           String    @id @default(cuid())
  address      String
  normalizedAddress String?
  propertyIdentityKey String?
  sourceFingerprint String?
  sourceRecordVersion Int @default(1)
  lastSourceChangedAt DateTime?
  changeSummary Json?
  cityId       String?
  city         City?     @relation(fields: [cityId], references: [id], onDelete: SetNull)
  countyId     String?
  county       County?   @relation(fields: [countyId], references: [id], onDelete: SetNull)
  state        String    @default("IA")
  zip          String?
  subdivision  String?
  lotNumber    String?
  parcelNumber String?   @unique
  landValue    Decimal?  @db.Decimal(12, 2)
  improvementValue Decimal? @db.Decimal(12, 2)
  parcel       Parcel?
  permits      Permit[]
  notes        Note[]
  activities   Activity[]
  plotOpportunities PlotOpportunity[]

  @@index([propertyIdentityKey])
  @@index([normalizedAddress, cityId, countyId])
}

model PlotOpportunity {
  id                   String            @id @default(cuid())
  organizationId       String
  organization         Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  propertyId           String?
  property             Property?         @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  permitId             String?
  permit               Permit?           @relation(fields: [permitId], references: [id], onDelete: SetNull)
  builderId            String?
  builder              Builder?          @relation(fields: [builderId], references: [id], onDelete: SetNull)
  sourceId             String?
  source               Source?           @relation(fields: [sourceId], references: [id], onDelete: SetNull)
  assignedMembershipId String?
  assignedMembership   Membership?       @relation(fields: [assignedMembershipId], references: [id], onDelete: SetNull)
  opportunityIdentityKey String?
  sourceFingerprint    String?
  sourceRecordVersion  Int               @default(1)
  lastSourceChangedAt  DateTime?
  scoreBreakdown       Json?
  requiresReview       Boolean           @default(false)
  duplicateRiskScore   Int               @default(0)
  currentStage         PipelineStage     @default(NEW)
  address              String?
  city                 String?
  county               String?
  subdivision          String?
  parcelNumber         String?
  lotNumber            String?
  builderName          String?
  likelyCompanyName    String?
  rawSourceName        String?
  normalizedEntityName String?
  preferredSalesName   String?
  legalEntityName      String?
  roleType             EntityRoleType @default(UNKNOWN)
  entityConfidenceScore Int           @default(0)
  roleConfidenceScore  Int           @default(0)
  contactQualityTier   ContactQualityTier @default(RESEARCH_REQUIRED)
  contactQualityScore  Int           @default(0)
  contactQualityBand   ContactQualityBand @default(TIER_5)
  preferredContactTarget String?
  contractorRegistrationNumber String?
  contractorRegistrationStatus RegistrationStatus @default(UNKNOWN)
  businessEntityNumber String?
  businessEntityStatus RegistrationStatus @default(UNKNOWN)
  mailingAddress       String?
  cityState            String?
  permitNumber         String?
  sourceName           String?
  sourceJurisdiction   String?
  sourceUrl            String?
  classification       PermitClassification @default(UNKNOWN_NEEDS_REVIEW)
  signalType           SignalType        @default(OTHER)
  developmentStage     DevelopmentStage  @default(PERMIT_REVIEW)
  sourceStrength       SourceStrength    @default(MEDIUM)
  readinessToContact   ReadinessToContact @default(RESEARCH)
  clusterId            String?
  projectSegment       ProjectSegment    @default(SINGLE_FAMILY)
  opportunityType      OpportunityType
  buildReadiness       BuildReadiness
  bidStatus            BidStatus         @default(NOT_REVIEWED)
  vacancyConfidence    Int               @default(0)
  opportunityScore     Int               @default(0)
  contactedAt          DateTime?
  lastContactedAt      DateTime?
  nextFollowUpAt       DateTime?
  followUpNeeded       Boolean           @default(false)
  interestStatus       String?
  outcomeStatus        String?
  contactSummary       String?
  notesSummary         String?
  outreachCount        Int               @default(0)
  callCount            Int               @default(0)
  emailCount           Int               @default(0)
  textCount            Int               @default(0)
  reasonLost           String?
  internalNotes        String?
  externalSummary      String?
  quoteRequestedAt     DateTime?
  quoteSentAt          DateTime?
  contactStatus        String?
  nextAction           String?
  nextFollowUpDate     DateTime?
  inquiredAt           DateTime?
  needsFollowUp        Boolean           @default(false)
  suggestedFollowUpDate DateTime?
  secondFollowUpDate   DateTime?
  followedUpOn         DateTime?
  notes                Json?
  closedAt             DateTime?
  signalDate           DateTime
  sourceEvidence       Json?
  matchProvenance      Json?
  contactResolutionStatus ContactResolutionStatus @default(UNKNOWN)
  lastContactResolutionRunAt DateTime?
  lastEnrichedAt       DateTime?
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt
  contacts             Contact[]
  activities           Activity[]
  entityMatches        EntityMatch[]
  enrichmentResults    EnrichmentResult[]
  stageHistory         OpportunityStageHistory[]
  contactSnapshot      OpportunityContactSnapshot?
  reviewQueueItems     ReviewQueueItem[]

  @@index([organizationId, opportunityScore])
  @@index([organizationId, currentStage, nextFollowUpAt])
  @@index([opportunityIdentityKey])
  @@index([organizationId, bidStatus, opportunityScore])
  @@index([organizationId, currentStage, updatedAt])
}

model Parcel {
  id           String    @id @default(cuid())
  propertyId   String    @unique
  property     Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  parcelNumber String    @unique
}

model Permit {
  id                    String               @id @default(cuid())
  sourceId              String?
  source                Source?              @relation(fields: [sourceId], references: [id], onDelete: SetNull)
  jurisdictionId        String?
  jurisdiction          Jurisdiction?        @relation(fields: [jurisdictionId], references: [id], onDelete: SetNull)
  propertyId            String?
  property              Property?            @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  builderId             String?
  builder               Builder?             @relation(fields: [builderId], references: [id], onDelete: SetNull)
  permitIdentityKey     String?
  sourceFingerprint     String?
  sourceRecordVersion   Int                  @default(1)
  lastSourceChangedAt   DateTime?
  changeSummary         Json?
  permitNumber          String
  permitType            String
  permitSubtype         String?
  permitStatus          String
  applicationDate       DateTime?
  issueDate             DateTime?
  projectDescription    String?
  estimatedProjectValue Decimal?             @db.Decimal(12, 2)
  landValue             Decimal?             @db.Decimal(12, 2)
  improvementValue      Decimal?             @db.Decimal(12, 2)
  ownerName             String?
  contractorName        String?
  developerName         String?
  sourceUrl             String
  classification        PermitClassification @default(UNKNOWN_NEEDS_REVIEW)
  dedupeHash            String               @unique
  rawRecords            RawRecord[]
  plotOpportunities     PlotOpportunity[]

  @@unique([permitNumber, sourceUrl])
  @@index([permitIdentityKey])
  @@index([issueDate, permitStatus])
}

model Lead {
  id                     String             @id @default(cuid())
  organizationId         String
  organization           Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  builderId              String?
  builder                Builder?           @relation(fields: [builderId], references: [id], onDelete: SetNull)
  companyId              String?
  company                Company?           @relation(fields: [companyId], references: [id], onDelete: SetNull)
  stage                  PipelineStage      @default(NEW)
  assignedMembershipId   String?
  assignedMembership     Membership?        @relation(fields: [assignedMembershipId], references: [id], onDelete: SetNull)
  outreachCount          Int                @default(0)
  callCount              Int                @default(0)
  emailCount             Int                @default(0)
  lastContactDate        DateTime?
  nextFollowUpDate       DateTime?
  interestStatus         String?
  score                  Int                @default(0)
  clusterOpportunityScore Int               @default(0)
  activities             Activity[]
  notes                  Note[]
  tags                   LeadTag[]
  history                LeadStageHistory[]
  watchlists             Watchlist[]
  scoreSnapshots         LeadScoreSnapshot[]
}

model LeadStageHistory {
  id        String        @id @default(cuid())
  leadId    String
  lead      Lead          @relation(fields: [leadId], references: [id], onDelete: Cascade)
  stage     PipelineStage
  changedAt DateTime      @default(now())
  note      String?
}

model OpportunityStageHistory {
  id                    String        @id @default(cuid())
  organizationId        String
  organization          Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  opportunityId         String
  opportunity           PlotOpportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  fromStage             PipelineStage?
  toStage               PipelineStage
  fromBidStatus         BidStatus?
  toBidStatus           BidStatus
  note                  String?
  sourceLabel           String?
  changedByMembershipId String?
  changedByMembership   Membership?   @relation("OpportunityStageChangedByMembership", fields: [changedByMembershipId], references: [id], onDelete: SetNull)
  changedAt             DateTime      @default(now())

  @@index([opportunityId, changedAt])
}

model OpportunityContactSnapshot {
  id                       String                @id @default(cuid())
  organizationId           String
  organization             Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  opportunityId            String                @unique
  opportunity              PlotOpportunity       @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  primaryEntityId          String?
  primaryEntity            Builder?              @relation("SnapshotPrimaryEntity", fields: [primaryEntityId], references: [id], onDelete: SetNull)
  primaryContactId         String?
  primaryContact           Contact?              @relation("SnapshotPrimaryContact", fields: [primaryContactId], references: [id], onDelete: SetNull)
  primaryEntityName        String?
  primaryContactName       String?
  primaryPhone             String?
  primaryEmail             String?
  primaryWebsite           String?
  contactQualityTier       ContactQualityTier    @default(RESEARCH_REQUIRED)
  contactQualityBand       ContactQualityBand    @default(TIER_5)
  contactQualityScore      Int                   @default(0)
  entityConfidenceScore    Int                   @default(0)
  nextBestAction           String?
  contactResolutionStatus  ContactResolutionStatus @default(UNKNOWN)
  resolutionNotes          String?
  lastContactResolutionRunAt DateTime?
  createdAt                DateTime              @default(now())
  updatedAt                DateTime              @updatedAt
}

model Activity {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  leadId         String?
  lead           Lead?        @relation(fields: [leadId], references: [id], onDelete: Cascade)
  opportunityId  String?
  opportunity    PlotOpportunity? @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  contactId      String?
  contact        Contact?     @relation(fields: [contactId], references: [id], onDelete: SetNull)
  propertyId     String?
  property       Property?    @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  type           String
  direction      String?
  occurredAt     DateTime     @default(now())
  outcome        String?
  note           String?
  description    String?
  createdByMembershipId String?
  createdByMembership Membership? @relation("ActivityCreatedByMembership", fields: [createdByMembershipId], references: [id], onDelete: SetNull)
  createdAt      DateTime     @default(now())

  @@index([opportunityId, occurredAt])
}

model Note {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  leadId         String?
  lead           Lead?        @relation(fields: [leadId], references: [id], onDelete: Cascade)
  propertyId     String?
  property       Property?    @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  body           String
  createdAt      DateTime     @default(now())
}

model Tag {
  id    String    @id @default(cuid())
  name  String    @unique
  leads LeadTag[]
}

model LeadTag {
  leadId String
  tagId  String
  lead   Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)
  tag    Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([leadId, tagId])
}

model Watchlist {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  leadId         String?
  lead           Lead?        @relation(fields: [leadId], references: [id], onDelete: Cascade)
  watchType      String
  watchValue     String
}

model EntityMatch {
  id                   String         @id @default(cuid())
  organizationId       String
  organization         Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  builderId            String?
  builder              Builder?       @relation(fields: [builderId], references: [id], onDelete: Cascade)
  companyId            String?
  company              Company?       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  plotOpportunityId    String?
  plotOpportunity      PlotOpportunity? @relation(fields: [plotOpportunityId], references: [id], onDelete: Cascade)
  rawSourceName        String
  normalizedEntityName String
  preferredSalesName   String?
  fingerprint          String
  roleType             EntityRoleType @default(UNKNOWN)
  roleConfidenceScore  Int            @default(0)
  matchScore           Int            @default(0)
  matchStrategy        String
  sourceLabel          String
  sourceUrl            String?
  rationale            String?
  payload              Json?
  isPrimary            Boolean        @default(false)
  createdAt            DateTime       @default(now())
  lastCheckedAt        DateTime       @default(now())
}

model EnrichmentResult {
  id               String       @id @default(cuid())
  organizationId   String
  organization     Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  builderId        String?
  builder          Builder?     @relation(fields: [builderId], references: [id], onDelete: Cascade)
  companyId        String?
  company          Company?     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  plotOpportunityId String?
  plotOpportunity  PlotOpportunity? @relation(fields: [plotOpportunityId], references: [id], onDelete: Cascade)
  provider         String
  fieldName        String?
  fieldValue       String?
  sourceLabel      String?
  sourceUrl        String?
  rationale        String?
  payload          Json
  confidence       Int
  refreshedAt      DateTime     @default(now())
  lastVerifiedAt   DateTime?
}

model SourceHealthCheck {
  id                String           @id @default(cuid())
  organizationId    String
  organization      Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  sourceId          String
  source            Source           @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  runId             String?
  run               SourceSyncRun?   @relation(fields: [runId], references: [id], onDelete: SetNull)
  status            SourceSyncStatus
  checkedAt         DateTime         @default(now())
  httpStatus        Int?
  fetchedCount      Int              @default(0)
  normalizedCount   Int              @default(0)
  parseFailureCount Int              @default(0)
  missingFieldCount Int              @default(0)
  duplicateCount    Int              @default(0)
  blockedCount      Int              @default(0)
  completenessScore Int              @default(0)
  healthScore       Int              @default(0)
  warningFlags      Json?
  errorMessage      String?
  notes             String?
}

model ReviewQueueItem {
  id               String            @id @default(cuid())
  organizationId   String
  organization     Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  sourceId         String?
  source           Source?           @relation(fields: [sourceId], references: [id], onDelete: SetNull)
  rawRecordId      String?
  rawRecord        RawRecord?        @relation(fields: [rawRecordId], references: [id], onDelete: SetNull)
  builderId        String?
  builder          Builder?          @relation(fields: [builderId], references: [id], onDelete: SetNull)
  opportunityId    String?
  opportunity      PlotOpportunity?  @relation(fields: [opportunityId], references: [id], onDelete: SetNull)
  reviewType       ReviewQueueType
  status           ReviewQueueStatus @default(OPEN)
  priority         Int               @default(50)
  title            String
  details          String?
  rationale        String?
  sourceUrl        String?
  fingerprint      String?
  confidenceScore  Int               @default(0)
  firstSeenAt      DateTime          @default(now())
  lastSeenAt       DateTime          @default(now())
  resolvedAt       DateTime?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@index([organizationId, status, priority])
  @@index([sourceId, status])
  @@index([opportunityId, status])
}

model LeadScoreSnapshot {
  id                     String   @id @default(cuid())
  leadId                 String
  lead                   Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  score                  Int
  clusterOpportunityScore Int
  reasons                Json
  createdAt              DateTime @default(now())
}

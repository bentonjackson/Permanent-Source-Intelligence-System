{
  "name": "permanent-source-intelligence-system",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:seed": "tsx prisma/seed.ts",
    "worker:sync": "tsx workers/run-source-sync.ts",
    "diagnostics": "tsx workers/run-diagnostics.ts",
    "worker:dedupe": "tsx -e \"import { runDuplicateCleanup } from './lib/jobs/source-sync'; runDuplicateCleanup().then((result) => { console.log(JSON.stringify(result, null, 2)); process.exit(0); }).catch((error) => { console.error(error); process.exit(1); });\"",
    "worker:enrich": "tsx -e \"import { runBuilderEnrichment } from './lib/enrichment/builder-enrichment'; runBuilderEnrichment().then((result) => { console.log(JSON.stringify(result, null, 2)); process.exit(0); }).catch((error) => { console.error(error); process.exit(1); });\"",
    "worker:backfill-identities": "npm run worker:enrich",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@clerk/nextjs": "^6.31.9",
    "@prisma/client": "^5.13.0",
    "@radix-ui/react-scroll-area": "^1.0.5",
    "@tanstack/react-table": "^8.17.3",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "date-fns": "^3.6.0",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.378.0",
    "next": "^14.2.3",
    "pdf-parse": "^2.4.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwind-merge": "^2.3.0",
    "xlsx": "^0.18.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@playwright/test": "^1.43.1",
    "@types/leaflet": "^1.9.12",
    "@types/node": "^20.12.8",
    "@types/react": "^18.3.2",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.19",
    "postcss": "^8.4.38",
    "prisma": "^5.13.0",
    "tailwindcss": "^3.4.3",
    "tsx": "^4.9.3",
    "typescript": "^5.4.5",
    "vitest": "^1.5.2"
  }
}
